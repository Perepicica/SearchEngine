<!DOCTYPE html>
<html lang="ru" dir="ltr">
<head>
    <style>
   .fig {
   margin-top: 100px;
    text-align: center; /* Выравнивание по центру */
   }
   .input{
   border: solid #d3d3d3;
   outline: 0;
   padding-left: 10px;
   height: 30px;
   border-radius: 20px; /*Закругляем уголки*/
   }
  .button{
   border: solid #d3d3d3;
   outline: 0;
   height: 30px;
   border-radius: 20px; /*Закругляем уголки*/
  }
    </style>
</head>
<body>
<div class="fig">
    <form>
        <input class="input" type="text" size="55" name="search">
        <input class="button" type="submit" value="Search">
    </form>
</div>
</body>
</html>